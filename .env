# Server
NODE_ENV=development
PORT=3000

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5432/techshop_db?schema=public"

# JWT — CHANGE THESE IN PRODUCTION!
JWT_ACCESS_SECRET=techshop-access-secret-key-dev-2024
JWT_REFRESH_SECRET=techshop-refresh-secret-key-dev-2024
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — allow Flutter web dev, React, Swagger UI
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173,http://localhost:4200

# Rate Limiting: 100 req per 15 min
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
